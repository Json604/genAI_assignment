# ─────────────────────────────────────────────────────────────
# persona.chat — environment variables
# Copy this file to .env.local and fill in your own key.
# .env.local is gitignored — never commit real keys.
# ─────────────────────────────────────────────────────────────

# Required. Get a free key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional. Override the model. Defaults to gemini-2.5-flash.
# GEMINI_MODEL=gemini-2.5-flash
