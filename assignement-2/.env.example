# Choose ONE provider. If both are set, GEMINI_API_KEY wins.

# --- Option A: Google Gemini (direct) ---
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Option B: OpenRouter (gateway to many models) ---
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model override. Defaults:
#   gemini provider     -> gemini-2.5-flash
#   openrouter provider -> openai/gpt-4.1-mini
# Other good picks via OpenRouter: anthropic/claude-3.5-sonnet, google/gemini-2.5-flash
MODEL=
