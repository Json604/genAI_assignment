# ── LLM provider (gemini | openai | anthropic | openrouter) ──
LLM_PROVIDER=gemini
LLM_MODEL=gemini-3.1-flash-lite

# Provider API keys — only the active provider's key is required
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# ── Browser ──
BROWSER_HEADLESS=false
BROWSER_SLOW_MO=0
# Real Chrome via CDP (isolated agent profile). Run: npm run chrome:cdp
BROWSER_CDP_URL=http://127.0.0.1:9222

# ── Agent limits ──
MAX_ITERATIONS=60
SNAPSHOT_CHAR_LIMIT=8000
BACKGROUND_REVIEW=true
MEMORY_NUDGE_INTERVAL=3